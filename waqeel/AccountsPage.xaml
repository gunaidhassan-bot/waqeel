<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="waqeel.AccountsPage"
    Title="تفاصيل الحسابات">

    <!-- القسم الأيسر: لوحة التحكم والتعديل -->
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
    <Label Text="تفاصيل الحساب" FontAttributes="Bold" FontSize="18" TextColor="#2B3F5C" />

    <Frame Padding="15" BorderColor="#D1D1D1" CornerRadius="10">
        <VerticalStackLayout Spacing="12">
            <!-- لاحظ استخدام IsEnabled و IsReadOnly للتحكم بالحالة -->
            <Entry x:Name="TxtCode" Placeholder="رقم الحساب" 
                   IsReadOnly="True" BackgroundColor="#F5F5F5" TextColor="Gray" />

            <Entry x:Name="TxtName" Placeholder="اسم الحساب" 
                   IsReadOnly="True" BackgroundColor="#F5F5F5" />

            <Picker x:Name="PkrParent" Title="يتبع لحساب (الأب)" 
                    IsEnabled="False" BackgroundColor="#F5F5F5" />

            <Picker x:Name="PkrType" Title="نوع الحساب" 
                    IsEnabled="False" BackgroundColor="#F5F5F5">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>رئيسي (أب)</x:String>
                        <x:String>فرعي (تحليلي)</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Entry x:Name="TxtBalance" Placeholder="الرصيد الحالي" 
                   IsReadOnly="True" BackgroundColor="#E0E0E0" FontAttributes="Bold" />
        </VerticalStackLayout>
    </Frame>

    <!-- صف الأزرار التفاعلية -->
    <FlexLayout Wrap="Wrap" JustifyContent="SpaceEvenly" Margin="0,10,0,0">
        <Button x:Name="BtnNew" Text="جديد" Clicked="OnNewClicked" WidthRequest="90" BackgroundColor="#2ECC71" TextColor="White"/>
        <Button x:Name="BtnEdit" Text="تعديل" Clicked="OnEditClicked" WidthRequest="90" BackgroundColor="#F1C40F" TextColor="Black"/>
        <Button x:Name="BtnSave" Text="حفظ" Clicked="OnSaveClicked" WidthRequest="90" BackgroundColor="#3498DB" TextColor="White" IsEnabled="False"/>
        <Button x:Name="BtnCancel" Text="تراجع" Clicked="OnCancelClicked" WidthRequest="90" BackgroundColor="#95A5A6" TextColor="White" IsEnabled="False"/>
        <Button x:Name="BtnDelete" Text="حذف" Clicked="OnDeleteClicked" WidthRequest="90" BackgroundColor="#E74C3C" TextColor="White"/>
        <Button x:Name="BtnPrint" Text="طباعة" Clicked="OnPrintClicked" WidthRequest="90" BackgroundColor="#34495E" TextColor="White"/>
    </FlexLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
